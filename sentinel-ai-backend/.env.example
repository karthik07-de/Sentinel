# ============================================================
# SENTINEL AI BACKEND - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================================

# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_PREFIX=api/v1

# Database
DATABASE_URL="postgresql://sentinel:sentinel_password@localhost:5432/sentinel_ai?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# Argon2
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Sentinel AI <noreply@sentinelai.io>"

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# OAuth - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# AWS S3 (or compatible - e.g. Supabase Storage, MinIO)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=sentinel-ai-uploads
AWS_S3_ENDPOINT=

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048

# Google Gemini (fallback AI provider)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# AI Provider to use: openai | gemini
AI_PROVIDER=openai

# Security APIs
VIRUSTOTAL_API_KEY=your-virustotal-api-key
GOOGLE_SAFE_BROWSING_API_KEY=your-gsb-api-key
URLSCAN_API_KEY=your-urlscan-api-key
WHOIS_API_KEY=your-whois-api-key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_TTL=60000
RATE_LIMIT_AUTH_MAX=10

# BullMQ
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=

# Stripe (Billing)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PREMIUM_PRICE_ID=price_xxx
STRIPE_FAMILY_PRICE_ID=price_xxx

# Feature Flags
ENABLE_EMAIL_VERIFICATION=false
ENABLE_MFA=true
ENABLE_GOOGLE_OAUTH=false
ENABLE_GITHUB_OAUTH=false
